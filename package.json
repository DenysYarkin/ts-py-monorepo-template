{
  "name": "my-monorepo",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "generated/*",
    "specs"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "turbo": "latest",
    "typescript-eslint": "^8.54.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --max-warnings=0"
    ],
    "*.{css,scss,md}": [
      "prettier --write"
    ]
  },
  "scripts": {
    "prepare": "husky"
  }
}
