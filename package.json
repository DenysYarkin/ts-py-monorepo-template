{
  "name": "my-monorepo",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "generated/*",
    "specs"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "turbo": "latest",
    "typescript-eslint": "^8.54.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --max-warnings=0"
    ],
    "*.{css,scss,md}": [
      "prettier --write"
    ]
  },
  "scripts": {
    "prepare": "husky",
    "docker:db:prepare": "docker compose --env-file .env.docker up -d db api && docker compose --env-file .env.docker exec api alembic upgrade head",
    "docker:db:teardown": "docker compose --env-file .env.docker down -v",
    "docker:db:migrate": "docker compose --env-file .env.docker exec api alembic upgrade head",
    "docker:up": "docker compose --env-file .env.docker up",
    "docker:up:detached": "docker compose --env-file .env.docker up -d",
    "docker:down": "docker compose --env-file .env.docker down",
    "frontend:dev": "npx turbo run frontend:dev",
    "api:dev": "npx turbo run api:dev",
    "all:dev": "npm run frontend:dev && npm run api:dev"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21"
  }
}
