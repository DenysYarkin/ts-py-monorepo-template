{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "generate:client:py": {
      "inputs": ["../../openapi/**"],
      "outputs": ["schemas/generated.py"],
      "cache": true
    },
    "generate:client:ts": {
      "inputs": ["../../openapi/**"],
      "outputs": ["generated/api/**"],
      "cache": true
    },

    "migrations:run": { "cache": false },
    "migrations:revert:last": { "cache": false },
    "migrations:create:auto": { "cache": false },
    "migrations:create": { "cache": false },

    "build": {
      "dependsOn": ["generate:client:py", "generate:client:ts", "^build"],
      "outputs": [".next/**", "dist/**"]
    },

    "api:dev": {
      "cache": false,
      "persistent": true
    },
    "frontend:dev": {
      "cache": false,
      "persistent": true
    }
  }
}
